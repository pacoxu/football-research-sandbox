{
  "meta": {
    "id": "uefa-youth-league",
    "name": { "zh": "欧洲青年冠军联赛", "en": "UEFA Youth League" },
    "scope": { "zh": "最近三个已完成赛季；中日韩按 UEFA 官方国籍尽量完整，其他国家仅精选。", "en": "The latest three completed seasons, with comprehensive CJK coverage by UEFA nationality and curated players from elsewhere." },
    "checked_at": "2026-07-12"
  },
  "qualification": {
    "applies_from": "2024/25",
    "paths": [
      {
        "id": "champions-league-path",
        "title": { "zh": "欧冠路径", "en": "Champions League path" },
        "description": { "zh": "参加 UEFA 欧冠联赛阶段的 36 家俱乐部，其青年队进入青年欧冠联赛阶段，赛程和对手与成年队前六轮对应。前 22 名晋级三十二强。", "en": "The youth teams of the 36 clubs in the UEFA Champions League league phase enter a six-match league phase mirroring the senior fixtures. The top 22 reach the round of 32." },
        "source_ids": ["rules-2026-entries", "format-2026"]
      },
      {
        "id": "domestic-champions-path",
        "title": { "zh": "国内青年冠军路径", "en": "Domestic champions path" },
        "description": { "zh": "各 UEFA 会员协会的国内青年冠军进入最多三轮主客场淘汰赛，10 支球队晋级三十二强；协会若没有合资格青年赛事，可不产生参赛队。", "en": "Domestic youth champions from UEFA member associations enter up to three two-legged knockout rounds, producing ten round-of-32 qualifiers; associations without an eligible youth competition may have no entrant." },
        "source_ids": ["rules-2026-entries", "format-2026"]
      }
    ],
    "holder_rule": { "zh": "卫冕冠军若未通过其他方式获得资格，保证进入国内青年冠军路径第二轮。", "en": "The title holders are guaranteed a place in round two of the domestic champions path if they have not otherwise qualified." },
    "duplicate_rule": { "zh": "同时符合两条路径的俱乐部进入欧冠路径；其国内青年冠军名额通常由该协会青年联赛亚军顺延。", "en": "A club qualifying through both routes enters the Champions League path; its domestic berth normally passes to the youth league runners-up from that association." },
    "source_ids": ["rules-2026-entries", "format-2026"]
  },
  "player_eligibility": {
    "season": "2025/26",
    "birth_year_minimum": 2007,
    "overage_birth_year_minimum": 2006,
    "overage_season_list_limit": 5,
    "overage_match_list_limit": 3,
    "season_list_limit": 40,
    "match_list_limit": 20,
    "club_trained_match_list_minimum": 14,
    "rules": [
      { "id": "age", "title": { "zh": "年龄", "en": "Age" }, "description": { "zh": "2025/26 赛季原则上须出生于 2007 年 1 月 1 日或以后；最多可报名 5 名出生于 2006 年 1 月 1 日或以后且满足俱乐部培养年限的球员，每场 20 人名单中最多使用其中 3 人。", "en": "For 2025/26, players are generally born on or after 1 January 2007. Up to five players born on or after 1 January 2006 may be registered if they satisfy club-training conditions, with no more than three on a 20-player match list." }, "source_ids": ["rules-2026-eligibility", "rules-2026-lists"] },
      { "id": "lists", "title": { "zh": "报名与比赛名单", "en": "Registration and match lists" }, "description": { "zh": "赛季球员名单最多 40 人且至少包含 4 名门将；每场比赛提交 20 人名单。球员必须注册在参赛俱乐部，且同赛季只能代表一家俱乐部参赛。", "en": "The season list contains up to 40 players and at least four goalkeepers; each match uses a 20-player shortlist. Players must be registered with the entrant and may represent only one club in the competition that season." }, "source_ids": ["rules-2026-lists"] },
      { "id": "club-trained", "title": { "zh": "本俱乐部培养", "en": "Club-trained requirement" }, "description": { "zh": "每场 20 人名单中至少 14 人须在 15 岁生日后连续为本俱乐部效力两年，或在三年内累计两年（其中最多一年可租借至同协会俱乐部）。", "en": "At least 14 players on each 20-player list must have been registered with the club for two uninterrupted years after turning 15, or for two of three years with at most one year on loan within the same association." }, "source_ids": ["rules-2026-eligibility", "rules-2026-lists"] },
      { "id": "senior-cap", "title": { "zh": "成年 UEFA 赛事限制", "en": "Senior UEFA appearance cap" }, "description": { "zh": "球员一旦从联赛阶段起在 UEFA 成年俱乐部赛事累计出场 3 场或以上，即不再具备该赛季青年欧冠参赛资格。", "en": "Once a player has appeared in three or more UEFA senior club-competition matches from the league phase onward, they are no longer eligible for that season's Youth League." }, "source_ids": ["rules-2026-eligibility"] }
    ]
  },
